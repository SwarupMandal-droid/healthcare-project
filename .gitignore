# ===========================
# Python / Django
# ===========================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
venv/
env/
.venv/
.env_dir/
Env/

# Django specific
*.log
local_settings.py
db.sqlite3-journal

# Media files (user uploads)

# Static files collected by collectstatic
staticfiles/
static_root/

# ===========================
# Environment & Secrets
# ===========================
.env
.env.*
!.env.example

# ===========================
# Database dumps / backups
# ===========================
*.sql
*.dump
*.bak

# ===========================
